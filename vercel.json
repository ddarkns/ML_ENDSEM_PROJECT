{
    "builds": [
      {
        "src": "frontend/package.json",
        "use": "@vercel/next"
      },
      {
        "src": "core/main.py",
        "use": "@vercel/python"
      }
    ],
    "rewrites": [
      {
        "source": "/api/(.*)",
        "destination": "/core/main.py"
      },
      {
        "source": "/(.*)",
        "destination": "/frontend/$1"
      }
    ]
  }